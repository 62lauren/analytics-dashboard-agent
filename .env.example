# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Salesforce credentials
SALESFORCE_USERNAME=your.user@company.com
SALESFORCE_PASSWORD=YourPassword123
SALESFORCE_SECURITY_TOKEN=yourSecurityToken

# Salesforce Connected App — required for newer orgs (SOAP login is disabled by default)
SALESFORCE_CLIENT_ID=3MVG9...yourConsumerKey
SALESFORCE_CLIENT_SECRET=yourConsumerSecret

# "login" for production/developer orgs, "test" for sandboxes
SALESFORCE_DOMAIN=login

# Your org's My Domain URL — required for newer orgs (find it in your Salesforce browser URL)
# Example: orgname-dev-ed.develop.my.salesforce.com
SALESFORCE_INSTANCE_URL=

# Server
PORT=8000
